# Development
DATABASE_URL=sqlite+aiosqlite:///./data/incidents_dev.db
REDIS_URL=redis://localhost:6379/0

# Production (override in production)
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/incidents_db
# DATABASE_URL_SYNC=postgresql://user:pass@localhost:5432/incidents_db

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI/ML Settings
MODEL_PATH=../IA-module/models
VECTORIZER_PATH=../IA-module/models

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Prometheus
ENABLE_PROMETHEUS=true
